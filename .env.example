# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key   # Server-side only

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key                         # Server-side only

# ─── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://getpostpilot.vercel.app

# ─── Razorpay (Payments) ───────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx                   # Frontend key
RAZORPAY_KEY_ID=rzp_live_xxx                               # Server-side
RAZORPAY_KEY_SECRET=your_razorpay_key_secret               # Server-side only

# ─── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx                                      # Server-side only
RESEND_FROM_EMAIL=PostPilot AI <hello@getpostpilot.vercel.app>  # Optional

# ─── Cron Security ─────────────────────────────────────────────────────────────
CRON_SECRET=your_random_cron_secret                        # Set in Vercel + vercel.json

# ─── Twitter / X OAuth ─────────────────────────────────────────────────────────
# Create app at developer.twitter.com → OAuth 2.0 → PKCE
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# ─── LinkedIn OAuth ────────────────────────────────────────────────────────────
# Create app at linkedin.com/developers
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# ─── Meta (Facebook + Instagram) ───────────────────────────────────────────────
# Create app at developers.facebook.com → add Facebook Login + Instagram Graph API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id               # Optional — for ad tracking

# ─── Pinterest OAuth ───────────────────────────────────────────────────────────
# Create app at developers.pinterest.com
PINTEREST_APP_ID=your_pinterest_app_id
PINTEREST_APP_SECRET=your_pinterest_app_secret

# ─── Google (YouTube OAuth) ────────────────────────────────────────────────────
# Create credentials at console.cloud.google.com → enable YouTube Data API v3
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Optional Analytics & Chat ─────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx                            # PostHog analytics
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com           # PostHog host
NEXT_PUBLIC_CRISP_WEBSITE_ID=your_crisp_website_id         # Crisp live chat
